# Team Service — Environment Variables
# Copy this file to .env and fill in your values.

APP_ENV=development
APP_NAME="Team Service"
APP_URL=http://localhost:8001

DB_HOST=localhost
DB_NAME=team_service
DB_USER=root
DB_PASS=

# Set to 1 on Hostinger (adds /public/ prefix to all URLs)
FORCE_PUBLIC_PREFIX=0
